## Part 1: Unit Testing (1.5 hours)

### 1.1 Basic Test Structure

```go
// In module/user/bl_test.go

package user

import (
    "context"
    "errors"
    "testing"
)

// Test convention: func Test<FunctionName>(t *testing.T)
func TestGetUser_Success(t *testing.T) {
    // Arrange: Set up test data
    mockRepo := &MockRepository{
        users: map[string]*User{
            "user_123": {ID: "user_123", Name: "John"},
        },
    }
    service := NewService(mockRepo, nil)

    // Act: Execute the code being tested
    user, err := service.GetUser(context.Background(), "user_123")

    // Assert: Verify the result
    if err != nil {
        t.Fatalf("Expected no error, got %v", err)
    }
    if user.Name != "John" {
        t.Errorf("Expected name John, got %s", user.Name)
    }
}

func TestGetUser_NotFound(t *testing.T) {
    mockRepo := &MockRepository{users: make(map[string]*User)}
    service := NewService(mockRepo, nil)

    user, err := service.GetUser(context.Background(), "nonexistent")

    if err == nil {
        t.Fatal("Expected error for nonexistent user")
    }
    if user != nil {
        t.Errorf("Expected nil user, got %v", user)
    }
}
```

### 1.2 Mock Objects

```go
// In module/user/mocks_test.go

package user

import "context"

// MockRepository implements Repository interface
type MockRepository struct {
    users map[string]*User
}

func (m *MockRepository) GetByID(ctx context.Context, id string) (*User, error) {
    if user, ok := m.users[id]; ok {
        return user, nil
    }
    return nil, errors.New("not found")
}

func (m *MockRepository) Create(ctx context.Context, user *User) error {
    m.users[user.ID] = user
    return nil
}

func (m *MockRepository) ListByTenant(ctx context.Context) ([]*User, error) {
    users := []*User{}
    for _, u := range m.users {
        users = append(users, u)
    }
    return users, nil
}

// MockLogger
type MockLogger struct {
    messages []string
}

func (m *MockLogger) Info() *zerolog.Event {
    return zerolog.New(io.Discard).Info()
}

// Or use testing/iotest
```

### 1.3 Table-Driven Tests

```go
// Test multiple scenarios efficiently

func TestValidateEmail(t *testing.T) {
    tests := []struct {
        name    string
        email   string
        wantErr bool
    }{
        {"Valid email", "user@example.com", false},
        {"Missing @", "userexample.com", true},
        {"Missing domain", "user@", true},
        {"Empty string", "", true},
    }

    for _, tt := range tests {
        t.Run(tt.name, func(t *testing.T) {
            err := ValidateEmail(tt.email)
            if (err != nil) != tt.wantErr {
                t.Errorf("ValidateEmail() error = %v, wantErr %v", err, tt.wantErr)
            }
        })
    }
}
```

### 1.4 Using testify/assert

```go
// Ellume Core often uses testify for assertions

import (
    "testing"
    "github.com/stretchr/testify/assert"
    "github.com/stretchr/testify/require"
)

func TestUserService_GetUser(t *testing.T) {
    mockRepo := &MockRepository{}
    service := NewService(mockRepo)

    user, err := service.GetUser(context.Background(), "123")

    // assert: test continues even if assertion fails
    assert.NoError(t, err)
    assert.Equal(t, "John", user.Name)

    // require: test stops if assertion fails
    require.NotNil(t, user)
    require.Equal(t, "123", user.ID)
}
```


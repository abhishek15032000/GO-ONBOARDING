## Part 2: Integration Testing (1.5 hours)

### 2.1 Integration Test Setup

```go
// In module/user/dl_integration_test.go

//go:build integration
// +build integration

package user

import (
    "context"
    "database/sql"
    "os"
    "testing"
    "ellume-core/pkg/logger"
    "ellume-core/pkg/provider"
)

// Integration tests run against real database
// Run with: go test -tags=integration ./module/user/

func setupIntegrationTest(t *testing.T) (*DataLayer, *sql.DB) {
    t.Helper()

    // Get database from environment (set by local-integration-test.sh)
    dsn := os.Getenv("POSTGRES_TEST_DSN")
    if dsn == "" {
        dsn = os.Getenv("DATABASE_DSN")
    }

    // Connect to database
    db, err := sql.Open("postgres", dsn)
    require.NoError(t, err)

    // Verify connection
    err = db.Ping()
    require.NoError(t, err)

    // Create DL
    dl := &DataLayer{db: db}

    return dl, db
}

func TestCreate_Integration(t *testing.T) {
    if testing.Short() {
        t.Skip("Skipping integration test")
    }

    dl, db := setupIntegrationTest(t)
    defer db.Close()

    // Cleanup after test
    defer db.Exec("DELETE FROM users WHERE id = $1", "test_user_123")

    // Create test user
    ctx := context.Background()
    user := &User{
        ID:       "test_user_123",
        Name:     "Integration Test",
        Email:    "test@example.com",
        TenantID: "test_tenant",
    }

    err := dl.Create(ctx, user)
    require.NoError(t, err)

    // Verify it was created
    retrieved, err := dl.GetByID(ctx, "test_user_123")
    require.NoError(t, err)
    assert.Equal(t, "Integration Test", retrieved.Name)
}
```

### 2.2 Running Tests

```bash
# Unit tests only
go test ./module/user

# With coverage
go test -cover ./module/user

# Generate coverage report
go test -coverprofile=coverage.out ./module/user
go tool cover -html=coverage.out  # Open in browser

# Integration tests only
go test -tags=integration ./module/user/...

# Specific test
go test -run TestCreate_Integration ./module/user

# Verbose
go test -v ./module/user
```


## Part 3: Data Layer Architecture (1.5 hours)

### 3.1 The Three-Layer Pattern

Ellume Core uses this pattern in every module:

```
HTTP Handler
    ↓ (passes data)
Business Logic
    ↓ (queries/updates)
Data Layer (Repository)
    ↓ (uses SQL)
Database
```

### 3.2 Writing a Data Layer (DL)

```go
// In module/user/dl.go (Data Layer)

package user

import (
    "context"
    "database/sql"
    "fmt"
)

// Repository interface defines what the DL can do
type Repository interface {
    GetByID(ctx context.Context, id string) (*User, error)
    Create(ctx context.Context, user *User) error
    Update(ctx context.Context, user *User) error
}

// User entity (matches database row)
type User struct {
    ID        string
    Name      string
    Email     string
    TenantID  string
    CreatedAt time.Time
}

// Concrete implementation
type DataLayer struct {
    db DatabaseProvider
}

func NewRepository(db DatabaseProvider) Repository {
    return &DataLayer{db: db}
}

// GetByID: Single user by ID (with tenant isolation)
func (dl *DataLayer) GetByID(ctx context.Context, id string) (*User, error) {
    tenantID, err := middleware.GetTenantIDFromContext(ctx)
    if err != nil {
        return nil, err
    }

    query := `
        SELECT id, name, email, tenant_id, created_at
        FROM users
        WHERE id = $1 AND tenant_id = $2
    `

    var user User
    if err := dl.db.DB().QueryRowContext(ctx, query, id, tenantID).
        Scan(&user.ID, &user.Name, &user.Email, &user.TenantID, &user.CreatedAt); err != nil {
        if err == sql.ErrNoRows {
            return nil, fmt.Errorf("user not found")
        }
        return nil, fmt.Errorf("query error: %w", err)
    }

    return &user, nil
}

// Create: Insert new user
func (dl *DataLayer) Create(ctx context.Context, user *User) error {
    tenantID, err := middleware.GetTenantIDFromContext(ctx)
    if err != nil {
        return err
    }

    query := `
        INSERT INTO users (id, name, email, tenant_id, created_at)
        VALUES ($1, $2, $3, $4, $5)
    `

    _, err = dl.db.DB().ExecContext(
        ctx, query,
        user.ID, user.Name, user.Email, tenantID, time.Now(),
    )
    if err != nil {
        return fmt.Errorf("insert failed: %w", err)
    }

    return nil
}
```


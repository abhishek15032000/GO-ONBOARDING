## Integration Test Example

```go
// In module/user/dl_integration_test.go

//go:build integration
// +build integration

package user

import (
    "context"
    "os"
    "testing"
)

func TestGetByID_Integration(t *testing.T) {
    // Setup
    dsn := os.Getenv("DATABASE_DSN")
    db := sql.Open("postgres", dsn)
    defer db.Close()

    repo := NewRepository(db)
    ctx := context.Background()

    // Create test user
    user := &User{ID: "test_1", Name: "John"}
    if err := repo.Create(ctx, user); err != nil {
        t.Fatal(err)
    }

    // Test retrieval
    retrieved, err := repo.GetByID(ctx, "test_1")
    if err != nil {
        t.Fatal(err)
    }

    if retrieved.Name != "John" {
        t.Errorf("Expected John, got %s", retrieved.Name)
    }

    // Cleanup
    db.Exec("DELETE FROM users WHERE id = $1", "test_1")
}
```


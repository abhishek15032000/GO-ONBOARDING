## Part 1: SQL and Query Building (2 hours)

### 1.1 Writing SQL Queries in Go

```go
package main

import (
    "database/sql"
    "fmt"
)

// Simple query with sqlx
func getUserByID(db *sql.DB, id string) {
    // Row represents a single result
    var name, email string
    row := db.QueryRow(
        "SELECT name, email FROM users WHERE id = $1",
        id,  // $1 is parameter placeholder (prevents SQL injection)
    )

    if err := row.Scan(&name, &email); err != nil {
        fmt.Println("Error:", err)
        return
    }

    fmt.Printf("User: %s (%s)\n", name, email)
}

// Query multiple rows
func getAllUsers(db *sql.DB) ([]string, error) {
    rows, err := db.Query("SELECT name FROM users ORDER BY created_at")
    if err != nil {
        return nil, err
    }
    defer rows.Close()  // CRITICAL: Always close row sets

    var names []string
    for rows.Next() {
        var name string
        if err := rows.Scan(&name); err != nil {
            return nil, err
        }
        names = append(names, name)
    }

    // Always check for errors from iteration
    if err := rows.Err(); err != nil {
        return nil, err
    }

    return names, nil
}

// Insert data
func createUser(db *sql.DB, name, email string) (int64, error) {
    result, err := db.Exec(
        "INSERT INTO users (name, email) VALUES ($1, $2)",
        name, email,
    )
    if err != nil {
        return 0, fmt.Errorf("insert failed: %w", err)
    }

    return result.LastInsertId()
}
```

### 1.2 Squirrel: Query Builder

In Ellume Core, we use Squirrel for safe, readable query building:

```go
import sq "github.com/Masterminds/squirrel"

// Build SELECT safely
query, args, _ := sq.Select("id", "name", "email").
    From("users").
    Where(sq.Gt{"age": 18}).
    OrderBy("created_at DESC").
    Limit(10).
    ToSql()

// Equivalent to:
// SELECT id, name, email FROM users WHERE age > $1 ORDER BY created_at DESC LIMIT 10
// args: [18]

// INSERT
query, args, _ := sq.Insert("users").
    Columns("name", "email", "age").
    Values("John", "john@example.com", 30).
    ToSql()

// UPDATE with WHERE
query, args, _ := sq.Update("users").
    Set("age", 31).
    Set("updated_at", time.Now()).
    Where(sq.Eq{"id": "123"}).
    ToSql()

// DELETE with WHERE
query, args, _ := sq.Delete("users").
    Where(sq.Eq{"id": "123"}).
    ToSql()
```

### 1.3 Multi-tenant Queries (Critical in Ellume Core)

**EVERY query must include tenant_id in WHERE clause:**

```go
// CORRECT: Include tenant_id
func GetUsersByTenant(ctx context.Context, tenantID string) {
    tenantID, err := middleware.GetTenantIDFromContext(ctx)
    if err != nil {
        return nil, err
    }

    query, args, _ := sq.Select("id", "name").
        From("users").
        Where(sq.Eq{"tenant_id": tenantID}).  // CRITICAL
        ToSql()

    // Execute query...
}

// WRONG: Missing tenant_id filter
// query, args, _ := sq.Select("id", "name").
//     From("users").  // Exposes all users!
//     ToSql()
```


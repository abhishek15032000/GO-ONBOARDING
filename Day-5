## Part 1: Ellume Core Module Architecture (1.5 hours)

### 1.1 Three-Layer Architecture

Each module follows this pattern:

```
User Request
    ↓
HTTP Handler Layer
    ├─ Validates input
    ├─ Extracts context
    └─ Calls business logic
    ↓
Business Logic Layer (BL)
    ├─ Implements business rules
    ├─ Orchestrates data operations
    └─ Calls data layer
    ↓
Data Layer (DL)
    ├─ Queries database
    ├─ Maps rows to structs
    └─ No business logic here
    ↓
Database
```

### 1.2 A Complete Module

```go
// In module/user/user.go (shared types)

package user

type User struct {
    ID       string
    Name     string
    Email    string
    TenantID string
}

// In module/user/dl.go (Data Layer)

type Repository interface {
    GetByID(ctx context.Context, id string) (*User, error)
    Create(ctx context.Context, user *User) error
    ListByTenant(ctx context.Context) ([]*User, error)
}

type DataLayer struct {
    db provider.DatabaseProvider
}

func (dl *DataLayer) GetByID(ctx context.Context, id string) (*User, error) {
    tenantID, _ := middleware.GetTenantIDFromContext(ctx)
    // SQL query with tenant_id check
}

// In module/user/bl.go (Business Logic)

type Service interface {
    GetUser(ctx context.Context, id string) (*User, error)
    CreateUser(ctx context.Context, req *CreateUserRequest) (*User, error)
}

type BusinessLogic struct {
    repo Repository
    log  logger.Logger
}

func (bl *BusinessLogic) GetUser(ctx context.Context, id string) (*User, error) {
    log := logger.FromContext(ctx)

    user, err := bl.repo.GetByID(ctx, id)
    if err != nil {
        log.Error().Err(err).Msg("Failed to get user")
        return nil, err
    }

    return user, nil
}

// In module/user/handler.go (HTTP Layer)

type Handler struct {
    service Service
}

func (h *Handler) GetUser(w http.ResponseWriter, r *http.Request) {
    id := r.PathValue("id")

    user, err := h.service.GetUser(r.Context(), id)
    if err != nil {
        http.Error(w, "Not found", http.StatusNotFound)
        return
    }

    w.Header().Set("Content-Type", "application/json")
    json.NewEncoder(w).Encode(user)
}
```

### 1.3 Module Registration

```go
// In module/user/init.go

func InitializeUserModule(
    db provider.DatabaseProvider,
    logger logger.Logger,
) (*Handler, error) {
    // Create data layer
    repo := NewRepository(db)

    // Create business logic
    service := NewService(repo, logger)

    // Create HTTP handler
    handler := NewHandler(service)

    return handler, nil
}

// In inithandler/modules.go

func InitializeModules(
    cfg *config.Config,
    dbProvider provider.DatabaseProvider,
    authProvider provider.AuthProvider,
    log logger.Logger,
) (map[string]interface{}, error) {
    modules := make(map[string]interface{})

    // Initialize each module
    userHandler, err := user.InitializeUserModule(dbProvider, log)
    if err != nil {
        return nil, err
    }
    modules["user"] = userHandler

    authHandler, err := auth.InitializeAuthModule(authProvider, dbProvider, log)
    if err != nil {
        return nil, err
    }
    modules["auth"] = authHandler

    return modules, nil
}
```


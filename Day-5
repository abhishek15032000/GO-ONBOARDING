## Part 2: Startup Sequence (1 hour)

### 2.1 The Big Picture

```go
// In cmd/server/main.go

func main() {
    // Step 1: Load configuration from environment
    cfg, err := config.LoadConfig()
    if err != nil {
        log.Fatal("Config error:", err)
    }

    // Step 2: Initialize logger
    logInstance := logger.NewLogger(logger.Config{
        Level:       cfg.Logging.Level,
        PrettyPrint: cfg.Development.PrettyLogs,
    })
    ctx := logger.ToContext(context.Background(), logInstance)

    // Step 3: Initialize database provider
    dbProvider := provider.NewPostgreSQLProvider(&provider.Config{
        Driver: cfg.Database.Driver,
        DSN:    cfg.Database.DSN,
    })

    if _, err := dbProvider.Connect(ctx); err != nil {
        logInstance.Fatal().Err(err).Msg("Failed to connect to database")
    }
    defer dbProvider.Close()

    // Step 4: Run migrations
    if err := database.InitializeDatabase(dbProvider.DB()); err != nil {
        logInstance.Fatal().Err(err).Msg("Migration failed")
    }

    // Step 5: Initialize auth provider
    authProvider, err := initializeAuthProvider(cfg, logInstance)
    if err != nil {
        logInstance.Fatal().Err(err).Msg("Auth provider init failed")
    }
    defer authProvider.Close()

    // Step 6: Initialize modules
    modules, err := inithandler.InitializeModules(cfg, dbProvider, authProvider, logInstance)
    if err != nil {
        logInstance.Fatal().Err(err).Msg("Module init failed")
    }

    // Step 7: Set up routing
    router := setupRouter(modules)

    // Step 8: Apply middleware
    var handler http.Handler = router
    handler = middleware.RecoveryMiddleware(handler)
    handler = middleware.RequestIDMiddleware(handler)
    handler = middleware.LoggingMiddleware(handler)
    handler = middleware.CORSMiddleware(handler)

    // Step 9: Start server
    addr := fmt.Sprintf(":%d", cfg.Server.Port)
    logInstance.Info().Str("addr", addr).Msg("Server starting")

    if err := http.ListenAndServe(addr, handler); err != nil {
        logInstance.Fatal().Err(err).Msg("Server error")
    }
}

func setupRouter(modules map[string]interface{}) *http.ServeMux {
    router := http.NewServeMux()

    userHandler := modules["user"].(*user.Handler)
    router.HandleFunc("GET /api/users/{id}", userHandler.GetUser)

    authHandler := modules["auth"].(*auth.Handler)
    router.HandleFunc("POST /api/auth/login", authHandler.Login)

    return router
}
```


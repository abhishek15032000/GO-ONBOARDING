## Part 0: Configuration Fundamentals (1 hour)

### 0.1 Environment Variables

Configuration comes from environment variables, not files:

```bash
# Development
export SERVER_PORT=8181
export DATABASE_DSN="postgres://ellume:ellume_dev@localhost:5432/ellume_core"
export JWT_SECRET="my_secret_key_at_least_32_characters_long"
export AUTH_PROVIDER=mock
export LOGGING_LEVEL=debug

# Then run
./devops/local-run.sh

# Or use .env file
cat .env
# SERVER_PORT=8181
# DATABASE_DSN=...
```

### 0.2 Configuration in Code

```go
// In pkg/config/config.go

type Config struct {
    Server   ServerConfig
    Database DatabaseConfig
    JWT      JWTConfig
    Logging  LoggingConfig
    Auth     AuthConfig
}

type ServerConfig struct {
    Port int
    Host string
}

type DatabaseConfig struct {
    Driver string  // "postgres"
    DSN    string  // "postgres://user:pass@host/db"
}

type JWTConfig struct {
    Secret string
    TTL    time.Duration
}

type AuthConfig struct {
    Provider string  // "firebase", "cognito", "mock"
}

// Load configuration from environment
func LoadConfig() (*Config, error) {
    cfg := &Config{
        Server: ServerConfig{
            Port: getEnvInt("SERVER_PORT", 8181),
            Host: getEnv("SERVER_HOST", "localhost"),
        },
        Database: DatabaseConfig{
            Driver: getEnv("DATABASE_DRIVER", "postgres"),
            DSN:    getEnv("DATABASE_DSN", ""),  // Required
        },
        JWT: JWTConfig{
            Secret: getEnv("JWT_SECRET", ""),  // Required
        },
        Auth: AuthConfig{
            Provider: getEnv("AUTH_PROVIDER", "mock"),
        },
    }

    // Validate required fields
    if cfg.Database.DSN == "" {
        return nil, errors.New("DATABASE_DSN is required")
    }
    if cfg.JWT.Secret == "" {
        return nil, errors.New("JWT_SECRET is required")
    }

    return cfg, nil
}

func getEnv(key, defaultValue string) string {
    if value := os.Getenv(key); value != "" {
        return value
    }
    return defaultValue
}

func getEnvInt(key string, defaultValue int) int {
    if value := os.Getenv(key); value != "" {
        if intVal, err := strconv.Atoi(value); err == nil {
            return intVal
        }
    }
    return defaultValue
}
```


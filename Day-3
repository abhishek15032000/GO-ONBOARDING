## Part 3: Middleware Stack (1.5 hours)

### 3.1 Understanding Middleware

Middleware wraps handlers to add cross-cutting concerns:

```
Request
  ↓
RecoveryMiddleware (catches panics)
  ↓
RequestIDMiddleware (adds request ID to context)
  ↓
LoggingMiddleware (logs request/response)
  ↓
AuthMiddleware (checks authorization)
  ↓
Handler (your code)
  ↓
Response
```

### 3.2 Middleware Pattern

```go
// In pkg/middleware/middleware.go

type Middleware func(http.Handler) http.Handler

// Add request ID to context
func RequestIDMiddleware(next http.Handler) http.Handler {
    return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
        requestID := uuid.New().String()

        // Add to context
        ctx := context.WithValue(r.Context(), "requestID", requestID)
        r = r.WithContext(ctx)

        // Add to response header
        w.Header().Set("X-Request-ID", requestID)

        // Continue to next handler
        next.ServeHTTP(w, r)
    })
}

// Log all requests
func LoggingMiddleware(next http.Handler) http.Handler {
    return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
        log := logger.FromContext(r.Context())

        // Log request
        log.Info().
            Str("method", r.Method).
            Str("path", r.URL.Path).
            Msg("Request")

        // Continue to handler
        next.ServeHTTP(w, r)

        // Log response (after handler completes)
        log.Info().
            Str("method", r.Method).
            Str("path", r.URL.Path).
            Msg("Response")
    })
}

// Catch panics
func RecoveryMiddleware(next http.Handler) http.Handler {
    return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
        defer func() {
            if err := recover(); err != nil {
                log := logger.FromContext(r.Context())
                log.Error().
                    Interface("panic", err).
                    Msg("Handler panicked")

                w.Header().Set("Content-Type", "application/json")
                w.WriteHeader(http.StatusInternalServerError)
                json.NewEncoder(w).Encode(map[string]string{
                    "error": "Internal server error",
                })
            }
        }()

        next.ServeHTTP(w, r)
    })
}

// Chain middleware (apply them in order)
func Chain(handler http.Handler, middlewares ...Middleware) http.Handler {
    // Apply in reverse order (last middleware wraps the handler)
    for i := len(middlewares) - 1; i >= 0; i-- {
        handler = middlewares[i](handler)
    }
    return handler
}
```

### 3.3 Middleware Order in Ellume Core

```go
// In cmd/server/main.go (typical setup)

router := http.NewServeMux()

// Register routes
router.HandleFunc("GET /api/users", getUsersHandler)

// Wrap router with middleware (executed in reverse order)
var handler http.Handler = router

// Last middleware applied = first executed
handler = middleware.RecoveryMiddleware(handler)      // Outermost
handler = middleware.RequestIDMiddleware(handler)
handler = middleware.LoggingMiddleware(handler)
handler = middleware.CORSMiddleware(handler)          // Innermost

http.ListenAndServe(":8181", handler)
```


## Part 2: Ellume Core Handler Pattern (1.5 hours)

### 2.1 Handler Structure in Ellume Core

```go
// In module/user/handler.go

package user

import (
    "net/http"
    "ellume-core/pkg/logger"
)

// UserHandler wraps dependencies
type UserHandler struct {
    service UserService  // Depends on business logic
    logger  logger.Logger
}

// NewUserHandler creates a handler
func NewUserHandler(service UserService) *UserHandler {
    return &UserHandler{
        service: service,
    }
}

// GetUser handles GET /users/:id
func (h *UserHandler) GetUser(w http.ResponseWriter, r *http.Request) {
    // Extract logger from context (added by middleware)
    log := logger.FromContext(r.Context())

    // Get path parameter
    userID := r.PathValue("id")  // Go 1.22+ syntax
    if userID == "" {
        log.Warn().Msg("Missing user ID")
        http.Error(w, "User ID required", http.StatusBadRequest)
        return
    }

    // Call business logic
    user, err := h.service.GetUser(r.Context(), userID)
    if err != nil {
        log.Error().Err(err).Str("userID", userID).Msg("Failed to get user")
        http.Error(w, "User not found", http.StatusNotFound)
        return
    }

    // Return JSON
    w.Header().Set("Content-Type", "application/json")
    json.NewEncoder(w).Encode(user)
}

// CreateUser handles POST /users
func (h *UserHandler) CreateUser(w http.ResponseWriter, r *http.Request) {
    log := logger.FromContext(r.Context())

    // Parse request
    var req CreateUserRequest
    if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
        log.Warn().Err(err).Msg("Invalid request body")
        http.Error(w, "Invalid request", http.StatusBadRequest)
        return
    }
    defer r.Body.Close()

    // Call business logic
    user, err := h.service.CreateUser(r.Context(), &req)
    if err != nil {
        log.Error().Err(err).Msg("Failed to create user")
        http.Error(w, "Creation failed", http.StatusInternalServerError)
        return
    }

    // Return created
    w.Header().Set("Content-Type", "application/json")
    w.WriteHeader(http.StatusCreated)
    json.NewEncoder(w).Encode(user)
}
```


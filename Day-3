## Part 1: Go HTTP Handlers (1.5 hours)

### 1.1 Handler Functions

```go
package main

import (
    "encoding/json"
    "fmt"
    "net/http"
)

// Handler function signature: func(http.ResponseWriter, *http.Request)
func helloHandler(w http.ResponseWriter, r *http.Request) {
    // Write response
    w.Header().Set("Content-Type", "text/plain")
    fmt.Fprintf(w, "Hello, World!")
}

// JSON handler
type User struct {
    ID   string `json:"id"`
    Name string `json:"name"`
    Email string `json:"email"`
}

func getUserHandler(w http.ResponseWriter, r *http.Request) {
    // Check method
    if r.Method != http.MethodGet {
        http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
        return
    }

    // Get URL parameter
    userID := r.URL.Query().Get("id")  // /api/user?id=123
    if userID == "" {
        http.Error(w, "Missing id parameter", http.StatusBadRequest)
        return
    }

    // Create response
    user := User{ID: userID, Name: "John", Email: "john@example.com"}

    // Marshal to JSON
    w.Header().Set("Content-Type", "application/json")
    if err := json.NewEncoder(w).Encode(user); err != nil {
        http.Error(w, "Encoding error", http.StatusInternalServerError)
        return
    }
}

// POST handler with request body
func createUserHandler(w http.ResponseWriter, r *http.Request) {
    if r.Method != http.MethodPost {
        http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
        return
    }

    // Parse request body
    var user User
    if err := json.NewDecoder(r.Body).Decode(&user); err != nil {
        http.Error(w, "Invalid JSON", http.StatusBadRequest)
        return
    }
    defer r.Body.Close()

    // Process user...
    user.ID = "new_id"

    // Return created response
    w.Header().Set("Content-Type", "application/json")
    w.WriteHeader(http.StatusCreated)
    json.NewEncoder(w).Encode(user)
}

func main() {
    // Register handlers
    http.HandleFunc("/hello", helloHandler)
    http.HandleFunc("/api/user", getUserHandler)
    http.HandleFunc("/api/user/create", createUserHandler)

    // Start server
    fmt.Println("Server running on :8080")
    http.ListenAndServe(":8080", nil)
}
```

### 1.2 Handlers with Context

In production, we pass context to track request scope:

```go
import (
    "context"
    "log"
)

func getUserHandler(w http.ResponseWriter, r *http.Request) {
    ctx := r.Context()  // Get request context

    // Add to context (for middleware/handlers to use)
    ctx = context.WithValue(ctx, "requestID", "req_123")

    // Pass context to functions
    user, err := getUserFromDB(ctx, userID)
    if err != nil {
        // Logger can extract requestID from context
        log.Println(ctx.Value("requestID"), "Error:", err)
    }
}

func getUserFromDB(ctx context.Context, id string) (*User, error) {
    // Can access context values
    requestID := ctx.Value("requestID")
    log.Println("Fetching user", id, "for request", requestID)

    // Can use context for cancellation
    select {
    case <-ctx.Done():
        return nil, ctx.Err()  // Request cancelled
    default:
    }

    // Query database...
    return &User{}, nil
}
```


## Part 3: Real Example - Add a Search Feature (2 hours)

Here's a complete walkthrough of adding a small feature:

### 3.1 Understand the Requirement

Let's add user search to the user module:

```
Endpoint: GET /api/users/search?q=<query>
Returns: List of users matching query (tenant-scoped)
```

### 3.2 TDD Approach - Start with Tests

```go
// module/user/bl_test.go

func TestSearchUsers_MatchesByName(t *testing.T) {
    mockRepo := &MockRepository{
        users: map[string]*User{
            "1": {ID: "1", Name: "John Smith", TenantID: "t1"},
            "2": {ID: "2", Name: "Jane Doe", TenantID: "t1"},
        },
    }
    service := NewService(mockRepo)

    results, err := service.SearchUsers(
        context.Background(),
        "john",
    )

    require.NoError(t, err)
    assert.Len(t, results, 1)
    assert.Equal(t, "John Smith", results[0].Name)
}

func TestSearchUsers_TenantIsolated(t *testing.T) {
    mockRepo := &MockRepository{
        users: map[string]*User{
            "1": {ID: "1", Name: "John", TenantID: "t1"},
            "2": {ID: "2", Name: "Jane", TenantID: "t2"},
        },
    }
    service := NewService(mockRepo)

    // Tenant t1 should only see user 1
    results, err := service.SearchUsers(
        // Add tenant ID to context
        context.Background(),
        "j",
    )

    require.NoError(t, err)
    assert.Len(t, results, 1)
    assert.Equal(t, "John", results[0].Name)
}
```

### 3.3 Implement Business Logic

```go
// module/user/bl.go

func (s *UserService) SearchUsers(
    ctx context.Context,
    query string,
) ([]*User, error) {
    log := logger.FromContext(ctx)

    // Validate input
    if query == "" {
        return []*User{}, nil  // Empty query returns empty list
    }

    if len(query) < 2 {
        return nil, errors.New("query must be at least 2 characters")
    }

    // Call repository
    users, err := s.repo.Search(ctx, query)
    if err != nil {
        log.Error().Err(err).Str("query", query).Msg("Search failed")
        return nil, fmt.Errorf("search error: %w", err)
    }

    log.Info().Int("count", len(users)).Str("query", query).Msg("Search completed")
    return users, nil
}
```

### 3.4 Implement Data Layer

```go
// module/user/dl.go

// Add to Repository interface
type Repository interface {
    // ... existing methods ...
    Search(ctx context.Context, query string) ([]*User, error)
}

// Implement in DataLayer
func (dl *DataLayer) Search(ctx context.Context, query string) ([]*User, error) {
    tenantID, err := middleware.GetTenantIDFromContext(ctx)
    if err != nil {
        return nil, err
    }

    // Use ILIKE for case-insensitive search
    sqlQuery := `
        SELECT id, name, email, tenant_id, created_at
        FROM users
        WHERE tenant_id = $1 AND (
            name ILIKE $2 OR email ILIKE $2
        )
        ORDER BY name
        LIMIT 50
    `

    rows, err := dl.db.DB().QueryContext(
        ctx, sqlQuery, tenantID, "%"+query+"%",
    )
    if err != nil {
        return nil, fmt.Errorf("query error: %w", err)
    }
    defer rows.Close()

    var users []*User
    for rows.Next() {
        var user User
        if err := rows.Scan(
            &user.ID, &user.Name, &user.Email, &user.TenantID, &user.CreatedAt,
        ); err != nil {
            return nil, fmt.Errorf("scan error: %w", err)
        }
        users = append(users, &user)
    }

    if err := rows.Err(); err != nil {
        return nil, err
    }

    return users, nil
}

// Integration test
func TestSearch_Integration(t *testing.T) {
    if testing.Short() {
        t.Skip("integration test")
    }

    dl, db := setupIntegrationTest(t)
    defer db.Close()
    defer db.Exec("DELETE FROM users WHERE tenant_id = $1", "test_tenant")

    // Create test data
    ctx := context.Background()
    users := []*User{
        {ID: "1", Name: "Alice Anderson", Email: "alice@test.com", TenantID: "test_tenant"},
        {ID: "2", Name: "Bob Smith", Email: "bob@test.com", TenantID: "test_tenant"},
    }

    for _, u := range users {
        require.NoError(t, dl.Create(ctx, u))
    }

    // Search test
    results, err := dl.Search(ctx, "alice")
    require.NoError(t, err)
    assert.Len(t, results, 1)
    assert.Equal(t, "Alice Anderson", results[0].Name)
}
```

### 3.5 Add HTTP Handler

```go
// module/user/handler.go

type SearchUsersRequest struct {
    Query string `json:"q"`
}

func (h *UserHandler) SearchUsers(w http.ResponseWriter, r *http.Request) {
    log := logger.FromContext(r.Context())

    // Get query parameter
    query := r.URL.Query().Get("q")
    if query == "" {
        http.Error(w, "Missing q parameter", http.StatusBadRequest)
        return
    }

    // Call service
    users, err := h.service.SearchUsers(r.Context(), query)
    if err != nil {
        log.Error().Err(err).Msg("Search failed")
        http.Error(w, "Search failed", http.StatusInternalServerError)
        return
    }

    // Return results
    w.Header().Set("Content-Type", "application/json")
    json.NewEncoder(w).Encode(map[string]interface{}{
        "results": users,
        "count":   len(users),
    })
}
```

### 3.6 Register Route

```go
// In cmd/server/main.go

func setupRouter(modules map[string]interface{}) *http.ServeMux {
    router := http.NewServeMux()

    userHandler := modules["user"].(*user.Handler)

    // Existing routes
    router.HandleFunc("GET /api/users/{id}", userHandler.GetUser)
    router.HandleFunc("POST /api/users", userHandler.CreateUser)

    // New route
    router.HandleFunc("GET /api/users/search", userHandler.SearchUsers)

    return router
}
```


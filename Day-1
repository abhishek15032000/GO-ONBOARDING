### 1.4 Collections: Arrays, Slices, Maps

```go
package main

import "fmt"

func main() {
    // ============ ARRAYS (fixed size) ============
    var numbers [5]int           // Array of 5 ints, initialized to [0,0,0,0,0]
    numbers = [5]int{1, 2, 3, 4, 5}
    fmt.Println(numbers[0])      // 1
    fmt.Println(len(numbers))    // 5

    // ============ SLICES (dynamic arrays) ============
    // This is what you'll use most of the time
    fruits := []string{"apple", "banana", "orange"}
    fmt.Println(fruits[0])       // "apple"
    fmt.Println(len(fruits))     // 3
    fmt.Println(cap(fruits))     // capacity

    // Append to slice
    fruits = append(fruits, "grape")
    fmt.Println(fruits)  // [apple banana orange grape]

    // Slice operations
    subset := fruits[1:3]        // "banana", "orange" (1 inclusive, 3 exclusive)
    all := fruits[:]             // entire slice
    from := fruits[2:]           // from index 2 to end

    // Iterate slices
    for i, fruit := range fruits {
        fmt.Printf("%d: %s\n", i, fruit)
    }

    // Make a slice with capacity
    capacity := make([]int, 10, 20)  // len=10, cap=20

    // ============ MAPS (key-value pairs) ============
    ages := make(map[string]int)
    ages["Alice"] = 30
    ages["Bob"] = 25

    // Direct initialization
    user := map[string]string{
        "name": "John",
        "city": "Boston",
    }

    // Access
    fmt.Println(ages["Alice"])   // 30
    fmt.Println(user["name"])    // "John"

    // Safe access (check if key exists)
    age, exists := ages["Charlie"]
    if exists {
        fmt.Println(age)
    } else {
        fmt.Println("Charlie not found")
    }

    // Iterate maps
    for key, value := range ages {
        fmt.Printf("%s: %d\n", key, value)
    }
}
```


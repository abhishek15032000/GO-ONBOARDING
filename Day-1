## Part 2: Functions and Error Handling (2 hours)

### 2.1 Functions

```go
package main

import "fmt"

// Simple function
func add(a int, b int) int {
    return a + b
}

// Multiple return values (Go idiom)
func divide(a, b int) (int, error) {
    if b == 0 {
        return 0, fmt.Errorf("division by zero")
    }
    return a / b, nil
}

// Named return values
func swap(a, b string) (first string, second string) {
    first = b
    second = a
    return  // implicit return with named values
}

// Variadic function (variable arguments)
func sum(numbers ...int) int {
    total := 0
    for _, num := range numbers {
        total += num
    }
    return total
}

// First-class function (can be assigned to variable)
type MathFunc func(int, int) int

func apply(fn MathFunc, a, b int) int {
    return fn(a, b)
}

func main() {
    fmt.Println(add(2, 3))      // 5

    result, err := divide(10, 2)
    if err != nil {
        fmt.Println("Error:", err)
    } else {
        fmt.Println("Result:", result)  // 5
    }

    x, y := swap("hello", "world")
    fmt.Println(x, y)  // world hello

    fmt.Println(sum(1, 2, 3, 4, 5))  // 15

    // Function as argument
    fmt.Println(apply(add, 5, 3))  // 8
}
```

### 2.2 Error Handling (Critical in Go)

```go
package main

import (
    "errors"
    "fmt"
)

// Error handling pattern 1: Return error as last return value
func readFile(filename string) (string, error) {
    // Simulate file read
    if filename == "" {
        return "", errors.New("filename cannot be empty")
    }
    return "file contents", nil
}

// Error handling pattern 2: Wrap errors with context
func processData(data string) error {
    if data == "" {
        return fmt.Errorf("processing failed: data is empty")
    }
    return nil
}

// Error handling pattern 3: Custom error type
type ValidationError struct {
    Field   string
    Message string
}

func (e ValidationError) Error() string {
    return fmt.Sprintf("validation error on %s: %s", e.Field, e.Message)
}

func main() {
    // Pattern: Check err immediately
    content, err := readFile("myfile.txt")
    if err != nil {
        fmt.Println("Error:", err)
        return
    }
    fmt.Println("Content:", content)

    // Pattern: Check multiple operations
    if err := processData("test"); err != nil {
        fmt.Println("Processing error:", err)
    }

    // Custom errors
    customErr := ValidationError{
        Field:   "email",
        Message: "invalid format",
    }
    fmt.Println(customErr.Error())
}
```

**CRITICAL GO PATTERN: `if err != nil`**

This pattern is everywhere in Go:

```go
// Always check errors immediately
result, err := someOperation()
if err != nil {
    // Handle or return the error
    return fmt.Errorf("operation failed: %w", err)  // %w wraps errors
}
// Continue with result
```


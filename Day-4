### 4.3 Cross-Tenant Access Prevention

```go
// Pattern: Return 404 for cross-tenant access (not 403)
// Prevents enumeration attacks

func (h *CustomerHandler) GetCustomer(w http.ResponseWriter, r *http.Request) {
    tenantID, _ := middleware.GetTenantIDFromContext(r.Context())
    customerID := r.PathValue("id")

    customer, err := h.service.GetCustomer(r.Context(), customerID)
    if err != nil {
        // Return 404 for any error (including cross-tenant)
        http.Error(w, "Not found", http.StatusNotFound)
        return
    }

    // Verify customer belongs to this tenant
    if customer.TenantID != tenantID {
        // WRONG: http.Error(w, "Forbidden", http.StatusForbidden)
        // RIGHT: return 404 to prevent enumeration
        http.Error(w, "Not found", http.StatusNotFound)
        return
    }

    w.Header().Set("Content-Type", "application/json")
    json.NewEncoder(w).Encode(customer)
}
```

### 4.4 Role-Based Authorization

```go
// For role-based access control

// RoleRequired middleware checks user role
func RoleRequired(roles ...string) func(http.Handler) http.Handler {
    return func(next http.Handler) http.Handler {
        return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
            claims, _ := r.Context().Value("claims").(*provider.Claims)

            // Check if user's role is in required roles
            allowed := false
            for _, role := range roles {
                if claims.Role == role {
                    allowed = true
                    break
                }
            }

            if !allowed {
                http.Error(w, "Forbidden", http.StatusForbidden)
                return
            }

            next.ServeHTTP(w, r)
        })
    }
}

// Usage:
// router.HandleFunc("DELETE /api/users/:id",
//     chain.Chain(
//         http.HandlerFunc(deleteHandler),
//         middleware.RoleRequired("admin"),
//     ).ServeHTTP,
// )
```


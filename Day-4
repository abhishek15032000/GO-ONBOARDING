## Part 1: JWT in Go (1.5 hours)

### 1.1 Verifying JWT Tokens

```go
// In pkg/authorization/jwt.go

import (
    "crypto/hmac"
    "crypto/sha256"
    "encoding/base64"
    "encoding/json"
    "fmt"
    "strings"
)

type Claims struct {
    Sub      string `json:"sub"`       // User ID
    TenantID string `json:"tenant_id"`
    Role     string `json:"role"`
    Exp      int64  `json:"exp"`       // Expiration unix timestamp
}

// VerifyToken checks if token is valid
func VerifyToken(token string, secret string) (*Claims, error) {
    parts := strings.Split(token, ".")
    if len(parts) != 3 {
        return nil, fmt.Errorf("invalid token format")
    }

    // In production, use a proper JWT library like golang-jwt
    // This is simplified for understanding

    // Decode payload
    payload := parts[1]
    decoded, err := base64.RawURLEncoding.DecodeString(payload)
    if err != nil {
        return nil, fmt.Errorf("decode error: %w", err)
    }

    var claims Claims
    if err := json.Unmarshal(decoded, &claims); err != nil {
        return nil, fmt.Errorf("unmarshal error: %w", err)
    }

    // Check expiration
    if time.Now().Unix() > claims.Exp {
        return nil, fmt.Errorf("token expired")
    }

    // Verify signature
    expectedSig := generateSignature(parts[0], parts[1], secret)
    if expectedSig != parts[2] {
        return nil, fmt.Errorf("invalid signature")
    }

    return &claims, nil
}

func generateSignature(header, payload, secret string) string {
    message := header + "." + payload
    signature := hmac.New(sha256.New, []byte(secret))
    signature.Write([]byte(message))
    return base64.RawURLEncoding.EncodeToString(signature.Sum(nil))
}
```

### 1.2 Using a JWT Library

```go
// In practice, use github.com/golang-jwt/jwt/v5

import "github.com/golang-jwt/jwt/v5"

type Claims struct {
    UserID   string `json:"user_id"`
    TenantID string `json:"tenant_id"`
    Role     string `json:"role"`
    jwt.RegisteredClaims
}

func VerifyToken(tokenString string, secret string) (*Claims, error) {
    claims := &Claims{}

    token, err := jwt.ParseWithClaims(
        tokenString,
        claims,
        func(token *jwt.Token) (interface{}, error) {
            // Return signing key
            return []byte(secret), nil
        },
    )

    if err != nil {
        return nil, fmt.Errorf("parse error: %w", err)
    }

    if !token.Valid {
        return nil, fmt.Errorf("invalid token")
    }

    return claims, nil
}
```


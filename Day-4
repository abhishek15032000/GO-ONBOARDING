### 2.3 Firebase Provider

```go
// In pkg/provider/firebase_auth.go

import "firebase.google.com/go/v4/auth"

type FirebaseAuthProvider struct {
    client *auth.Client
}

func (f *FirebaseAuthProvider) VerifyToken(ctx context.Context, token string) (*Claims, error) {
    // Verify with Firebase
    decodedToken, err := f.client.VerifyIDToken(ctx, token)
    if err != nil {
        return nil, fmt.Errorf("firebase verify failed: %w", err)
    }

    // Extract claims
    return &Claims{
        UserID:   decodedToken.UID,
        Email:    decodedToken.Claims["email"].(string),
        TenantID: decodedToken.Claims["tenant_id"].(string),
    }, nil
}
```

